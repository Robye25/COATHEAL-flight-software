[Unit]
Description=COATHEAL Onboard Flight Software
After=network-online.target time-sync.target
Wants=network-online.target

[Service]
# Type=notify so systemd uses our sd_notify READY=1 and WATCHDOG=1 messages.
Type=notify
NotifyAccess=main
User=coatheal
WorkingDirectory=/bexus/code/coatheal
ExecStartPre=/bexus/code/coatheal/scripts/preflight_healthcheck.sh /bexus/code/coatheal/config/onboard.example.ini
ExecStart=/bexus/code/coatheal/build/onboard/coatheal_onboard --config /bexus/code/coatheal/config/onboard.example.ini
Restart=always
RestartSec=2
StartLimitIntervalSec=120
StartLimitBurst=10
# BEXUS User Manual §5.9: hung-loop recovery. The main loop pings the watchdog
# every tick (default 1 Hz). 10 s gives 10 ticks of headroom before SIGKILL.
WatchdogSec=10
KillSignal=SIGINT
TimeoutStopSec=20
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
